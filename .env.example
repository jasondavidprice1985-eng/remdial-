# Database
POSTGRES_DB=remedial
POSTGRES_USER=remedial_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# Backend
DATABASE_URL=postgres://remedial_user:CHANGE_THIS@postgres:5432/remedial
PORT=3001
NODE_ENV=production
UPLOAD_DIR=/backend/uploads
CORS_ORIGIN=https://yourdomain.com

# JWT
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# Default users (created on first startup if not in DB)
MANAGER_USERNAME=manager
MANAGER_PASSWORD=CHANGE_THIS_MANAGER_PASSWORD
OFFICE_USERNAME=office
OFFICE_PASSWORD=CHANGE_THIS_OFFICE_PASSWORD
