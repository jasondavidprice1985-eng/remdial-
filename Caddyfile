yourdomain.com {
  # API and WebSocket
  handle /api/* {
    reverse_proxy backend:3001
  }

  handle /socket.io/* {
    reverse_proxy backend:3001 {
      header_up Connection {>Connection}
      header_up Upgrade {>Upgrade}
    }
  }

  # Static file uploads
  handle /uploads/* {
    reverse_proxy backend:3001
  }

  # Office dashboard
  handle /office* {
    uri strip_prefix /office
    reverse_proxy frontend-office:80
  }

  # Manager PWA (default)
  handle {
    reverse_proxy frontend-manager:80
  }
}
