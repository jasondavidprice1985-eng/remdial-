{
  "name": "remedial-e2e",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "codegen": "playwright codegen",
    "env:up": "docker compose -f docker-compose.e2e.yml up -d postgres",
    "env:down": "docker compose -f docker-compose.e2e.yml down -v"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "pg": "^8.21.0"
  }
}
